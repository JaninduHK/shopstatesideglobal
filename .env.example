# ============================================================
# State Side Global — PRODUCTION env
# Copy to `.env` on the server and fill in real values:
#   cp .env.example .env
# `.env` is gitignored — never commit real secrets.
# ============================================================

NODE_ENV=production
PORT=4000

# --- Public URLs (same origin: SPA + API on one domain) ---
CLIENT_URL=https://shopstatesideglobal.com
API_BASE_URL=https://shopstatesideglobal.com

# --- MongoDB (self-hosted container) ---
# Pick a strong password. Used both to initialize the mongo container
# and by the server to connect. authSource=admin because the root user
# is created in the admin database.
MONGO_USER=ssg_admin
MONGO_PASS=CHANGE_ME_long_random_password
MONGODB_URI=mongodb://ssg_admin:CHANGE_ME_long_random_password@mongo:27017/state_side_global?authSource=admin

# --- JWT secrets (generate with: openssl rand -base64 48) ---
JWT_ACCESS_SECRET=CHANGE_ME_access
JWT_REFRESH_SECRET=CHANGE_ME_refresh
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# --- Cookies (HTTPS in prod) ---
COOKIE_SECURE=true
COOKIE_DOMAIN=shopstatesideglobal.com

# --- Paystack (NOT READY YET — fill with LIVE keys before accepting payments) ---
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=
PAYSTACK_BASIC_PLAN_CODE=
PAYSTACK_ADDON1_PLAN_CODE=
PAYSTACK_ADDON2_PLAN_CODE=

# --- Cloudinary (you have this) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=

# --- Email provider: Mailjet (emails are mocked/logged if BOTH keys are blank) ---
# Both come from Mailjet dashboard → Account → API Key Management (REST API).
MAILJET_API_KEY=
MAILJET_SECRET_KEY=
# The sender address MUST be a validated sender / authenticated domain in Mailjet,
# otherwise sends are rejected.
EMAIL_FROM=no-reply@shopstatesideglobal.com
EMAIL_FROM_NAME=Shop StateSide Global

# --- Admin bootstrap ---
ADMIN_EMAIL=you@example.com
ADMIN_SETUP_SECRET=CHANGE_ME_one_time_setup_secret

# ============================================================
# Client build args (Vite inlines these at BUILD time).
# Changing these requires: docker compose up -d --build web
# ============================================================
VITE_PAYSTACK_PUBLIC_KEY=
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
